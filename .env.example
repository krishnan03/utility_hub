# ===========================================
# All-in-One Utility Hub — Environment Config
# ===========================================
# Copy this file to .env and adjust values as needed.
# All variables have sensible defaults.

# --- General ---
NODE_ENV=production

# --- Server ---
SERVER_PORT=3001

# --- File Storage ---
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE=104857600          # Max upload size in bytes (default: 100MB)
FILE_EXPIRY_HOURS=24             # Hours before uploaded files are auto-deleted

# --- Cleanup Service ---
CLEANUP_INTERVAL=0 * * * *      # Cron expression for cleanup job (default: every hour)

# --- CORS ---
CORS_ORIGIN=*                    # Allowed origins (use your domain in production)

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000      # Rate limit window in ms (default: 15 minutes)
RATE_LIMIT_MAX=100               # Max requests per window per IP

# --- Deployment / Nginx ---
HOST_PORT=80                     # Host port mapped to Nginx HTTP
# HOST_SSL_PORT=443              # Host port mapped to Nginx HTTPS (uncomment for SSL)
# DOMAIN=your-domain.com         # Your custom domain

# --- API Keys (optional, for external services) ---
# EXCHANGE_RATE_API_KEY=          # API key for currency exchange rates
