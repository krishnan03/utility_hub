{
  "name": "all-in-one-toolpilot",
  "version": "1.0.0",
  "private": true,
  "description": "A comprehensive suite of online utilities in a single place",
  "license": "MIT",
  "scripts": {
    "dev:client": "npm --prefix client run dev",
    "dev:server": "npm --prefix server run dev",
    "build:client": "npm --prefix client run build",
    "build:server": "npm --prefix server run build",
    "start:server": "npm --prefix server run start",
    "test": "npm --prefix client run test && npm --prefix server run test",
    "test:client": "npm --prefix client run test",
    "test:server": "npm --prefix server run test",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "install:all": "npm --prefix client install && npm --prefix server install"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
